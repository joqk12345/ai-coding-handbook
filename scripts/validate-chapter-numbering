#!/usr/bin/env python3
"""Validate chapter numbering between SUMMARY.md and chapter file H1 titles."""

from pathlib import Path
import re
import sys

SUMMARY = Path('SUMMARY.md')

# Match summary entries like: [第12章: 标题](part-4/chapter-12-building-agent.md)
ENTRY_RE = re.compile(r"\[第(\d+)章:\s*[^\]]*\]\((part-[2-5]/[^\)]+\.md)\)")
H1_RE = re.compile(r"^#\s*第(\d+)章(?:[:：]|\s)")


def main() -> int:
    if not SUMMARY.exists():
        print('ERROR: SUMMARY.md not found')
        return 1

    errors: list[str] = []
    lines = SUMMARY.read_text(encoding='utf-8').splitlines()

    for i, line in enumerate(lines, start=1):
        m = ENTRY_RE.search(line)
        if not m:
            continue

        expected_num = int(m.group(1))
        rel_path = m.group(2)
        file_path = Path(rel_path)

        if not file_path.exists():
            errors.append(
                f"SUMMARY.md:{i} -> missing file: {rel_path}"
            )
            continue

        file_lines = file_path.read_text(encoding='utf-8').splitlines()
        if not file_lines:
            errors.append(f"{rel_path}: empty file")
            continue

        h1 = file_lines[0].strip()
        h1_match = H1_RE.match(h1)
        if not h1_match:
            errors.append(
                f"{rel_path}:1 -> H1 must start with '# 第X章' (got: {h1})"
            )
            continue

        actual_num = int(h1_match.group(1))
        if actual_num != expected_num:
            errors.append(
                f"{rel_path}:1 -> expected 第{expected_num}章, got 第{actual_num}章"
            )

    if errors:
        print('Chapter numbering validation failed:')
        for err in errors:
            print(f'- {err}')
        return 1

    print('Chapter numbering validation passed.')
    return 0


if __name__ == '__main__':
    sys.exit(main())
